@baseUrl = http://localhost:8080
@categoryId = replace-with-category-id

### Health
GET {{baseUrl}}/health

### Readiness
GET {{baseUrl}}/ready

### Metrics
GET {{baseUrl}}/metrics

### Register
POST {{baseUrl}}/api/v1/users/register
Content-Type: application/json

{
  "email": "user@example.com",
  "username": "demo_user",
  "password": "Password@123"
}

### Login
POST {{baseUrl}}/api/v1/users/login
Content-Type: application/json

{
  "email": "user@example.com",
  "password": "Password@123"
}

### Forgot password
POST {{baseUrl}}/api/v1/users/forgot-password
Content-Type: application/json

{
  "email": "user@example.com"
}

### Reset password
POST {{baseUrl}}/api/v1/users/reset-password
Content-Type: application/json

{
  "token": "paste-reset-token",
  "password": "NewPassword@123"
}

### Create category
POST {{baseUrl}}/api/v1/categories
Content-Type: application/json

{
  "name": "Sample Category"
}

### Create product (multipart)
POST {{baseUrl}}/api/v1/products
Content-Type: multipart/form-data; boundary=boundary

--boundary
Content-Disposition: form-data; name="name"

Sample Product
--boundary
Content-Disposition: form-data; name="description"

Sample description
--boundary
Content-Disposition: form-data; name="category"

{{categoryId}}
--boundary
Content-Disposition: form-data; name="price"

99.99
--boundary
Content-Disposition: form-data; name="stock"

10
--boundary
Content-Disposition: form-data; name="media"; filename="sample.jpg"
Content-Type: image/jpeg

< ./sample.jpg
--boundary--

### Bulk create products (multipart)
POST {{baseUrl}}/api/v1/products/bulk
Content-Type: multipart/form-data; boundary=boundary

--boundary
Content-Disposition: form-data; name="products[0][name]"

Product A
--boundary
Content-Disposition: form-data; name="products[0][description]"

Description A
--boundary
Content-Disposition: form-data; name="products[0][category]"

{{categoryId}}
--boundary
Content-Disposition: form-data; name="products[0][price]"

10
--boundary
Content-Disposition: form-data; name="products[0][stock]"

12
--boundary
Content-Disposition: form-data; name="media_0"; filename="sample.jpg"
Content-Type: image/jpeg

< ./sample.jpg
--boundary--
