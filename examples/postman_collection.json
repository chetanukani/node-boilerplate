{
  "info": {
    "name": "Node Boilerplate API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "categoryId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "request": { "method": "GET", "url": "{{baseUrl}}/health" }
    },
    {
      "name": "Register",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"user@example.com\",\n  \"username\": \"demo_user\",\n  \"password\": \"Password@123\"\n}"
        },
        "url": "{{baseUrl}}/api/v1/users/register"
      }
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"Password@123\"\n}"
        },
        "url": "{{baseUrl}}/api/v1/users/login"
      }
    },
    {
      "name": "Create Category",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Sample Category\"\n}"
        },
        "url": "{{baseUrl}}/api/v1/categories"
      }
    },
    {
      "name": "Create Product",
      "request": {
        "method": "POST",
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "name", "value": "Sample Product", "type": "text" },
            {
              "key": "description",
              "value": "Sample description",
              "type": "text"
            },
            { "key": "category", "value": "{{categoryId}}", "type": "text" },
            { "key": "price", "value": "99.99", "type": "text" },
            { "key": "stock", "value": "10", "type": "text" },
            { "key": "media", "type": "file", "src": [] }
          ]
        },
        "url": "{{baseUrl}}/api/v1/products"
      }
    }
  ]
}
