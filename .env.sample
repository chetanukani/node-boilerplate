# ################# REQUIRED ENV VARS START #################
PORT=8080
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/node_boilerplate

ACCESS_TOKEN_SECRET=change-me-access-secret
ACCESS_TOKEN_EXPIRY=1d
REFRESH_TOKEN_SECRET=change-me-refresh-secret
REFRESH_TOKEN_EXPIRY=10d
EXPRESS_SESSION_SECRET=

CORS_ORIGIN=http://localhost:3000
HOST_URL=http://localhost:8080
FRONTEND_URL=http://localhost:3000

# Set true when running behind nginx/load balancer
TRUST_PROXY=false
# ################# REQUIRED ENV VARS END #################

# ################# OPTIONAL / INTEGRATIONS #################

SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_SENDER_NAME=Node Boilerplate

USE_S3=false
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=
AWS_S3_ENDPOINT=
AWS_S3_FORCE_PATH_STYLE=false

FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

APP_VERSION_CACHE_TTL_SECONDS=30

# Cron (node-cron). Set ENABLE_CRON=false to disable all scheduled jobs.
ENABLE_CRON=true
CRON_TIMEZONE=UTC

FORGOT_PASSWORD_REDIRECT_URL=http://localhost:3000/forgot-password

# Stripe payments (set ENABLE_STRIPE=true and provide keys to activate)
ENABLE_STRIPE=false
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_DEFAULT_CURRENCY=usd
STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:3000/payment/success
STRIPE_CHECKOUT_CANCEL_URL=http://localhost:3000/payment/cancel
